{
  "name": "datapath",
  "version": "0.1.0",
  "private": true,
  "description": "App de escritorio educativa para aprender Data Engineering",
  "author": "DataPath",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n NEXT,ELECTRON -c blue,green \"pnpm dev:next\" \"pnpm dev:electron\"",
    "dev:next": "next dev -p 3000",
    "dev:electron": "wait-on http://localhost:3000 && tsc -p electron/tsconfig.json && cross-env NODE_ENV=development electron .",
    "build:next": "next build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "pnpm build:next && pnpm build:electron",
    "dist": "pnpm build && electron-builder",
    "dist:win": "pnpm build && electron-builder --win",
    "lint": "eslint .",
    "type-check": "tsc --noEmit && tsc -p electron/tsconfig.json --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.460.0",
    "next": "^16.2.4",
    "next-intl": "^4.4.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^41.5.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.18.0",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "^10.0.1",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.1"
  },
  "engines": {
    "node": ">=20.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "esbuild", "unrs-resolver"]
  },
  "build": {
    "appId": "com.datapath.app",
    "productName": "DataPath",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": ["nsis"]
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.education"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Education"
    }
  }
}
