{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "../dist-electron",
    "rootDir": "..",
    "sourceMap": true,
    "baseUrl": ".."
  },
  "include": ["**/*.ts", "../src/lib/db/**/*.ts", "../src/lib/gamification/**/*.ts"]
}
